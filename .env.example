# Supabase -> Settings -> API -> service_role (GIZLI - paylasmayin)
# Kopyalayin: .env.example -> .env
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# PPE kamera API (run_ppe_flask.py)
PPE_API_URL=http://127.0.0.1:5002/api/status

# ESP32-CAM MJPEG (PC ile kamera ayni Wi-Fi aginda olmali)
# Ornek: telefon hotspot IP 192.168.43.94 ise:
PPE_STREAM_URL=http://192.168.43.94:81/stream
# Varsayilan: WebSocket (yerel ag, ngrok yok)
PPE_CAMERA_MODE=ws
# ESP32: ws://PC_IP:5002/ws/camera?api_key=fabrika_ortak_gizli_key_123&ts=...&device_id=esp32cam
# stream veya post icin: PPE_CAMERA_MODE=stream | post
# PPE_STREAM_URLS=http://192.168.43.94:81/stream,http://192.168.43.94/capture
